[Unit]
Description=DocuMind Streamlit UI
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/RAG
EnvironmentFile=/home/ubuntu/RAG/.env
ExecStart=/home/ubuntu/RAG/.venv/bin/streamlit run app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
